{
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "main.py",
      "methods": ["GET"],
      "headers": {
        "Access-Control-Allow-Origin": "https://somali-to-somali-dictionary.vercel.app"
      }
    }
  ]
}